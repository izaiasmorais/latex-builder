{
  "permissions": {
    "allow": [
      "Bash(latexmk:*)",
      "Bash(pdflatex:*)",
      "Bash(bibtex:*)",
      "Bash(pdfinfo:*)",
      "Bash(./scripts/compile.sh:*)",
      "Bash(./scripts/check.sh:*)",
      "Bash(scripts/compile.sh:*)",
      "Bash(scripts/check.sh:*)",
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git diff)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git branch:*)",
      "Bash(git fetch:*)",
      "Bash(git pull --rebase:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(ls:*)",
      "Bash(wc:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(rm:*)",
      "Bash(mv:*)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/scripts/guard.sh"
          }
        ]
      }
    ]
  }
}
